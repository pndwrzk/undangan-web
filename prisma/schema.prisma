generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Couple {
  id         String   @id @default(uuid())
  groomName  String
  groomAlias String?
  groomBio   String?  @db.Text
  groomImage String?  @default("/groom.png")
  brideName  String
  brideAlias String?
  brideBio   String?  @db.Text
  brideImage String?  @default("/bride.png")
  hashtag    String?  @default("#AlviaPandiwaMenyatu")
  heroImage  String?  @default("/hero.jpg")
  quoteImage String?  @default("/quote-bg.png")
  weddingDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RSVP {
  id         String   @id @default(uuid())
  name       String
  attendance String
  guests     String?
  guestId    String?  @unique
  createdAt  DateTime @default(now())
}

model Guestbook {
  id        String   @id @default(uuid())
  name      String
  message   String   @db.Text
  status    Int      @default(1)
  guestId   String?
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  likes     Int      @default(0)
  likedBy   GuestLike[]
  createdAt DateTime @default(now())
}

model GuestLike {
  id          String    @id @default(uuid())
  guestId     String
  guestbookId String
  guestbook   Guestbook @relation(fields: [guestbookId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([guestId, guestbookId])
}

model Guest {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  phone       String?
  group       String?
  partnerName String?
  side        Int      @default(0)
  wishes      Guestbook[]
  createdAt   DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  time      String
  date      String
  location  String
  address   String   @db.Text
  mapUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gift {
  id            String   @id @default(uuid())
  bankName      String
  accountNumber String
  accountName   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Story {
  id          String   @id @default(uuid())
  date        String
  title       String
  description String   @db.Text
  image       String?
  icon        String?  @default("Heart")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Song {
  id        String   @id @default(uuid())
  title     String
  artist    String?
  url       String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
